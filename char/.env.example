# CHAR — local env

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Cursor Agent SDK (service key for hack demo)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# Public URL Cursor cloud can reach for MCP (ngrok / Vercel)
CHAR_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
CHAR_MCP_SECRET=dev-secret

# Fallback repo when pitch-only cloud grill needs a clone target
CHAR_FALLBACK_REPO=https://github.com/gabikreal1/ios_cursor

# Hack toggles
CHAR_MOCK=1
CHAR_DEV_BYPASS=1
NEXT_PUBLIC_CHAR_DEV_BYPASS=1
